using Gtk 4.0;
template $AikadmWindow : Gtk.Window {
    can-focus: true;
    title: "Aikadm";

    Gtk.Overlay  {
        hexpand: true;
        vexpand: true;
        [overlay]
        Gtk.Box {
            Gtk.Label {
               label: "Hello World!";
            }
        }
        [overlay]
        Gtk.Box {
            Gtk.Label {
               label: "---------";
            }
        }
    }
}